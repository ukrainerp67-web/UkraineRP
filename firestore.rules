rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ukrainerp67@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'rada', 'banker', 'Президент', 'Депутат', 'Адмін']
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'ukrainerp67@gmail.com';
    }

    function isGovernment() {
      return isSignedIn() && (
        request.auth.token.email == 'ukrainerp67@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'rada', 'Президент', 'Депутат', 'Прем\'єр Міністр', 'Міністр фінансів']
      );
    }

    function isFrozen(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) && 
             get(/databases/$(database)/documents/users/$(userId)).data.get('isFrozen', false) == true &&
             get(/databases/$(database)/documents/users/$(userId)).data.get('email', '') != 'ukrainerp67@gmail.com';
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isSuperAdmin();
      allow update: if isSuperAdmin() || 
                    (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'socialRating', 'isFrozen'])) ||
                    (isAdmin() && existing().get('email', '') != 'ukrainerp67@gmail.com');
      allow delete: if isSuperAdmin();
    }

    // --- Message Rules ---
    match /messages/{messageId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (!isFrozen(request.auth.uid) || isAdmin());
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Property Rules ---
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // --- Vehicle Rules ---
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // --- Business Rules ---
    match /businesses/{businessId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || existing().ownerId == request.auth.uid;
    }

    // --- Mafia Rules ---
    match /mafias/{mafiaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Typing Status Rules ---
    match /typingStatus/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- Presence Rules ---
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- Notification Rules ---
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Basic check, data validated in app
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Friend Request Rules ---
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (resource == null || resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    // --- Global Events Rules ---
    match /global_events/{eventId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- System Rules ---
    match /system/budget {
      allow read: if isSignedIn();
      allow update: if isGovernment();
      allow create: if isSuperAdmin();
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- Health Check Rules ---
    match /_health_/{docId} {
      allow read: if true;
    }
  }
}
