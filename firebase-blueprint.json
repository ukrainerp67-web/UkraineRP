{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and game progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "sex": { "type": "string", "enum": ["M", "F"] },
        "birthDate": { "type": "string" },
        "passportPhoto": { "type": "string" },
        "signature": { "type": "string" },
        "balance": { "type": "number" },
        "socialRating": { "type": "number" },
        "status": { "type": "string" },
        "partnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "firstName", "lastName", "balance", "socialRating"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate owned by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "type": { "type": "string", "enum": ["smart", "two_room", "house", "villa", "island"] },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicles owned by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      }
    },
    "Business": {
      "title": "Business",
      "description": "Businesses owned by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "revenue": { "type": "number" },
        "isBlocked": { "type": "boolean" }
      }
    },
    "Fine": {
      "title": "Fine",
      "description": "Fines issued to users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "paid", "overdue"] }
      },
      "required": ["amount", "reason", "issuedAt", "deadline", "status"]
    },
    "Mafia": {
      "title": "Mafia",
      "description": "Crime organizations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "name": { "type": "string" },
        "members": { "type": "array" },
        "level": { "type": "number" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "recipientId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "readAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "error", "warning", "money", "work", "social"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "actionType": { "type": "string", "enum": ["friend_request", "bank_transfer"] },
        "actionData": { "type": "object" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "Friend requests between users",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "fromName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Presence": {
      "title": "Presence",
      "description": "User online status and heartbeat",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["online", "offline"] }
      },
      "required": ["uid", "lastActive", "status"]
    },
    "TypingStatus": {
      "title": "TypingStatus",
      "description": "Indicates if a user is currently typing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "isTyping": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "System": {
      "title": "System",
      "description": "Global system state and economy",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Player data"
    },
    "/users/{userId}/fines/{fineId}": {
      "schema": "Fine",
      "description": "Fines issued to the user"
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Property listings and ownership"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicle listings and ownership"
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business listings and ownership"
    },
    "/mafias/{mafiaId}": {
      "schema": "Mafia",
      "description": "Mafia organizations"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global and private messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/typingStatus/{userId}": {
      "schema": "TypingStatus",
      "description": "User typing indicators"
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "User friend requests"
    },
    "/presence/{userId}": {
      "schema": "Presence",
      "description": "Real-time user online status"
    },
    "/system/{docId}": {
      "schema": "System",
      "description": "Global system parameters like budget"
    }
  }
}
